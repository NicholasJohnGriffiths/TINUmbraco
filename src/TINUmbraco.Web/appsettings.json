{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "AzureKeyVault": {
    "VaultUri": "https://tinumbracokv.vault.azure.net/",
    "ConnectionStringSecretName": "umbraco-db-connection",
    "MediaConnectionStringSecretName": "umbraco-media-storage-connection",
    "StripeTestSecretKeySecretName": "stripe-test-secret-key",
    "StripeLiveSecretKeySecretName": "stripe-live-secret-key",
    "StripeTestWebhookSecretSecretName": "stripe-test-webhook-secret",
    "StripeLiveWebhookSecretSecretName": "stripe-live-webhook-secret"
  },
  "Stripe": {
    "PublishableKey": "",
    "SecretKey": "",
    "WebhookSecret": ""
  },
  "Umbraco": {
    "Storage": {
      "AzureBlob": {
        "Media": {
          "ContainerName": "media"
        },
        "ImageSharpCache": {
          "ContainerName": "cache"
        }
      }
    },
    "CMS": {
      "Global": {
        "Id": "d654c341-04a0-422c-88ea-ede6ffab3cbc",
        "UmbracoMediaPath": "~/media"
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "Security": {
        "AllowConcurrentLogins": false
      }
    }
  }
}
