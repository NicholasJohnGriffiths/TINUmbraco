@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<IPublishedContent>
@using System.Text.Json
@{
    Layout = "~/Views/_Master.cshtml";

    // Get the membership name and details
    string memberName = Model.Name;
    string? description = Model.Value<string>("description");
    string? companyType = Model.Value<string>("companyType");
    
    // Try to get logo from media picker
    IPublishedContent? logo = Model.Value<IPublishedContent>("logo");
    
    // websiteUrl is now a text field, but may still contain legacy MultiUrlPicker JSON.
    string? rawWebsiteUrl = Model.Value<string>("websiteUrl");
    string? websiteUrl = null;

    if (!string.IsNullOrWhiteSpace(rawWebsiteUrl))
    {
        string trimmed = rawWebsiteUrl.Trim();

        if (trimmed.StartsWith("[") || trimmed.StartsWith("{"))
        {
            try
            {
                using JsonDocument doc = JsonDocument.Parse(trimmed);
                JsonElement root = doc.RootElement;

                if (root.ValueKind == JsonValueKind.Array)
                {
                    foreach (JsonElement item in root.EnumerateArray())
                    {
                        if (item.ValueKind == JsonValueKind.Object
                            && item.TryGetProperty("url", out JsonElement urlProp)
                            && urlProp.ValueKind == JsonValueKind.String)
                        {
                            string? parsed = urlProp.GetString();
                            if (!string.IsNullOrWhiteSpace(parsed))
                            {
                                websiteUrl = parsed.Trim();
                                break;
                            }
                        }
                    }
                }
                else if (root.ValueKind == JsonValueKind.Object
                         && root.TryGetProperty("url", out JsonElement singleUrlProp)
                         && singleUrlProp.ValueKind == JsonValueKind.String)
                {
                    websiteUrl = singleUrlProp.GetString()?.Trim();
                }
            }
            catch (JsonException)
            {
                // Fall back to treating the value as a plain URL string.
            }
        }

        websiteUrl ??= trimmed;
    }
}

@if (Model.Parent is not null)
{
    <a class="back" href="@Model.Parent.Url()">Back to @Model.Parent.Name</a>
}

<h1 class="page-title">@memberName</h1>

@if (!string.IsNullOrWhiteSpace(companyType))
{
    <p class="member-type"><strong>Type:</strong> @companyType</p>
}

@if (logo is not null)
{
    <img class="member-logo" src="@logo.Url()" alt="@memberName logo" loading="eager" style="max-width: 300px; margin: 20px 0;" />
}

@if (!string.IsNullOrWhiteSpace(description))
{
    <article class="content">
        @Html.Raw(description)
    </article>
}

@if (!string.IsNullOrWhiteSpace(websiteUrl))
{
    <p style="margin-top: 20px;">
        <a href="@websiteUrl" target="_blank" class="btn btn-primary">Visit Website</a>
    </p>
}
