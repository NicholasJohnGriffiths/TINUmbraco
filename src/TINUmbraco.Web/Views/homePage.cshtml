@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<IPublishedContent>
@{
    Layout = "_Master.cshtml";

    bool IsTruthy(object? value)
    {
        static bool IsTruthyString(string? raw)
        {
            if (string.IsNullOrWhiteSpace(raw))
            {
                return false;
            }

            string normalized = raw.Trim().ToLowerInvariant();
            return normalized is not ("false" or "0" or "no" or "n" or "off" or "null");
        }

        return value switch
        {
            null => false,
            bool b => b,
            string s => IsTruthyString(s),
            IEnumerable<string> values => values.Any(IsTruthyString),
            _ => IsTruthyString(value.ToString())
        };
    }

    string pageTitle = Model.Value<string>("pageTitle") ?? Model.Name;
    string pageHeading = Model.Value<string>("pageHeading") ?? pageTitle;
    string heroText = Model.Value<string>("heroText") ?? "Welcome to TIN Umbraco.";
    IHtmlContent? mainContent = Model.Value<IHtmlContent>("mainContent");

    IReadOnlyList<IPublishedContent> sectionPages = Model
        .Children()
        .Where(x => x.IsVisible())
        .OrderBy(x => x.SortOrder)
        .ToList();

    IPublishedContent? membershipsPage = sectionPages
        .FirstOrDefault(x => string.Equals(x.ContentType.Alias, "membershipsPage", StringComparison.OrdinalIgnoreCase));

    IReadOnlyList<IPublishedContent> allMembershipItems = membershipsPage is null
        ? []
        : membershipsPage.Children().Where(x => x.IsVisible()).OrderBy(x => x.SortOrder).ToList();

    IReadOnlyList<IPublishedContent> sponsorMembershipItems = allMembershipItems
        .Where(x => IsTruthy(x.Value("currentSponsor")))
        .ToList();

    IReadOnlyList<IPublishedContent> sponsorLogos = sponsorMembershipItems
        .Where(x => x.Value<IPublishedContent>("logo") is not null)
        .ToList();
}
<section class="hero">
    <p class="kicker">Technology Investment Network</p>
    <h1 class="hero-title">@pageTitle</h1>
    <p class="lead">@heroText</p>
    <h2 class="section-title">@pageHeading</h2>

    @if (mainContent is not null)
    {
        <div class="body-content">@mainContent</div>
    }
</section>

@if (sponsorLogos.Count > 0)
{
    <section class="home-sponsors" aria-label="Sponsors">
        <h2 class="section-title">Sponsors</h2>
        <div class="home-sponsors__marquee" role="presentation">
            <div class="home-sponsors__track">
                @foreach (IPublishedContent sponsor in sponsorLogos)
                {
                    IPublishedContent? logo = sponsor.Value<IPublishedContent>("logo");
                    if (logo is not null)
                    {
                        <a class="home-sponsors__link" href="@sponsor.Url()" aria-label="Open @sponsor.Name">
                            <img class="home-sponsors__logo" src="@logo.Url()" alt="@sponsor.Name" loading="lazy" />
                        </a>
                    }
                }

                @foreach (IPublishedContent sponsor in sponsorLogos)
                {
                    IPublishedContent? logo = sponsor.Value<IPublishedContent>("logo");
                    if (logo is not null)
                    {
                        <a class="home-sponsors__link" href="@sponsor.Url()" tabindex="-1" aria-hidden="true">
                            <img class="home-sponsors__logo" src="@logo.Url()" alt="" loading="lazy" aria-hidden="true" />
                        </a>
                    }
                }
            </div>
        </div>
    </section>
}

@if (sectionPages.Count == 0)
{
    <div class="empty">
        No child sections are published under this homepage yet.
    </div>
}
else
{
    <section class="sections" aria-label="Site sections">
        @foreach (IPublishedContent childPage in sectionPages)
        {
            <a class="section-card" href="@childPage.Url()">
                <h2 class="section-title">@childPage.Name</h2>
                <span class="section-link">Open section</span>
            </a>
        }
    </section>
}
