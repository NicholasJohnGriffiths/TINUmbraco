@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<IPublishedContent>
@using Umbraco.Cms.Core
@using Umbraco.Cms.Core.Models
@using System.Text.Json
@{
    Layout = "~/Views/_Master.cshtml";

    string pageTitle = Model.Value<string>("pageTitle") ?? Model.Name;
    string pageHeading = Model.Value<string>("pageHeading") ?? pageTitle;
    string? heroText = Model.Value<string>("heroText");
    IHtmlContent? mainContent = Model.Value<IHtmlContent>("mainContent");

    bool isReportsPage = string.Equals(Model.ContentType.Alias, "reportsPage", StringComparison.OrdinalIgnoreCase);
    bool isNewsPage = string.Equals(Model.ContentType.Alias, "newsPage", StringComparison.OrdinalIgnoreCase);
    bool isEventsPage = string.Equals(Model.ContentType.Alias, "eventsPage", StringComparison.OrdinalIgnoreCase);
    bool isMembershipsPage = string.Equals(Model.ContentType.Alias, "membershipsPage", StringComparison.OrdinalIgnoreCase);
    bool usePagination = isReportsPage || isNewsPage || isEventsPage;
    const int pageSize = 12;

    DateTime GetPublishDateOrMin(IPublishedContent item)
    {
        object? raw = item.Value("publishDate");
        return raw switch
        {
            DateTimeOffset dto => dto.UtcDateTime,
            DateTime dt => dt,
            DateOnly d => d.ToDateTime(TimeOnly.MinValue),
            string s when DateTime.TryParse(s, out DateTime parsed) => parsed,
            _ => DateTime.MinValue
        };
    }

    IReadOnlyList<IPublishedContent> children = Model
        .Children()
        .Where(x => x.IsVisible())
        .OrderByDescending(x => isReportsPage ? GetPublishDateOrMin(x) : DateTime.MinValue)
        .ThenBy(x => isMembershipsPage ? x.Name : null, StringComparer.OrdinalIgnoreCase)
        .ThenBy(x => x.SortOrder)
        .ToList();

    int currentPage = 1;
    if (usePagination
        && int.TryParse(Context.Request.Query["page"], out int parsedPage)
        && parsedPage > 0)
    {
        currentPage = parsedPage;
    }

    int totalItems = children.Count;
    int totalPages = usePagination ? Math.Max(1, (int)Math.Ceiling(totalItems / (double)pageSize)) : 1;
    currentPage = Math.Min(currentPage, totalPages);

    IReadOnlyList<IPublishedContent> visibleChildren = usePagination
        ? children.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList()
        : children;

    string BuildPageUrl(int targetPage)
    {
        string basePath = Context.Request.Path.Value ?? string.Empty;
        return targetPage <= 1 ? basePath : $"{basePath}?page={targetPage}";
    }

    int firstPageToShow = Math.Max(1, currentPage - 2);
    int lastPageToShow = Math.Min(totalPages, currentPage + 2);

    string? GetCardImageUrl(IPublishedContent item, params string[] aliases)
    {
        static string? NormalizeImageUrl(string? value)
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                return null;
            }

            string raw = value.Trim();

            if (raw.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
                || raw.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
                || raw.StartsWith('/'))
            {
                return raw;
            }

            if (!raw.StartsWith("umb://", StringComparison.OrdinalIgnoreCase)
                && (raw.StartsWith("media/", StringComparison.OrdinalIgnoreCase)
                    || raw.StartsWith("uploads/", StringComparison.OrdinalIgnoreCase)))
            {
                return "/" + raw;
            }

            return null;
        }

        static string? TryGetUrlFromJson(string raw)
        {
            static string? ReadUrlFromObject(JsonElement obj)
            {
                if (obj.TryGetProperty("src", out JsonElement srcProp) && srcProp.ValueKind == JsonValueKind.String)
                {
                    return NormalizeImageUrl(srcProp.GetString());
                }

                if (obj.TryGetProperty("url", out JsonElement urlProp) && urlProp.ValueKind == JsonValueKind.String)
                {
                    return NormalizeImageUrl(urlProp.GetString());
                }

                return null;
            }

            try
            {
                using JsonDocument doc = JsonDocument.Parse(raw);
                JsonElement root = doc.RootElement;

                if (root.ValueKind == JsonValueKind.Object)
                {
                    return ReadUrlFromObject(root);
                }

                if (root.ValueKind == JsonValueKind.Array)
                {
                    foreach (JsonElement entry in root.EnumerateArray())
                    {
                        if (entry.ValueKind != JsonValueKind.Object)
                        {
                            continue;
                        }

                        string? parsed = ReadUrlFromObject(entry);
                        if (!string.IsNullOrWhiteSpace(parsed))
                        {
                            return parsed;
                        }
                    }
                }
            }
            catch (JsonException)
            {
                // Ignore malformed JSON-like values and continue with other fallbacks.
            }

            return null;
        }

        foreach (string alias in aliases)
        {
            MediaWithCrops? mediaWithCrops = item.Value<MediaWithCrops>(alias);
            if (mediaWithCrops is not null)
            {
                return mediaWithCrops.MediaUrl();
            }

            IPublishedContent? mediaItem = item.Value<IPublishedContent>(alias);
            if (mediaItem is not null)
            {
                return mediaItem.Url();
            }

            string? rawValue = item.Value<string>(alias);
            string? normalized = NormalizeImageUrl(rawValue);
            if (!string.IsNullOrWhiteSpace(normalized))
            {
                return normalized;
            }

            if (!string.IsNullOrWhiteSpace(rawValue)
                && UdiParser.TryParse(rawValue.Trim(), out Udi? udi)
                && udi is GuidUdi guidUdi)
            {
                IPublishedContent? mediaByUdi = Umbraco.Media(guidUdi.Guid);
                if (mediaByUdi is not null)
                {
                    return mediaByUdi.Url();
                }
            }

            if (!string.IsNullOrWhiteSpace(rawValue) && (rawValue.TrimStart().StartsWith('{') || rawValue.TrimStart().StartsWith('[')))
            {
                string? parsedFromJson = TryGetUrlFromJson(rawValue);
                if (!string.IsNullOrWhiteSpace(parsedFromJson))
                {
                    return parsedFromJson;
                }

                try
                {
                    using JsonDocument doc = JsonDocument.Parse(rawValue);
                    JsonElement root = doc.RootElement;
                    IEnumerable<JsonElement> objectNodes = root.ValueKind == JsonValueKind.Array
                        ? root.EnumerateArray().Where(x => x.ValueKind == JsonValueKind.Object)
                        : root.ValueKind == JsonValueKind.Object
                            ? [root]
                            : [];

                    foreach (JsonElement node in objectNodes)
                    {
                        if (node.TryGetProperty("mediaKey", out JsonElement mediaKeyProp)
                            && mediaKeyProp.ValueKind == JsonValueKind.String
                            && Guid.TryParse(mediaKeyProp.GetString(), out Guid mediaKey))
                        {
                            IPublishedContent? mediaByKey = Umbraco.Media(mediaKey);
                            if (mediaByKey is not null)
                            {
                                return mediaByKey.Url();
                            }
                        }

                        if (node.TryGetProperty("udi", out JsonElement udiProp)
                            && udiProp.ValueKind == JsonValueKind.String
                            && UdiParser.TryParse(udiProp.GetString(), out Udi? parsedUdi)
                            && parsedUdi is GuidUdi parsedGuidUdi)
                        {
                            IPublishedContent? mediaByParsedUdi = Umbraco.Media(parsedGuidUdi.Guid);
                            if (mediaByParsedUdi is not null)
                            {
                                return mediaByParsedUdi.Url();
                            }
                        }
                    }
                }
                catch (JsonException)
                {
                    // Ignore malformed JSON-like values and continue with other fallbacks.
                }
            }
        }

        return null;
    }
}
<h1 class="page-title">@pageHeading</h1>

@if (!string.IsNullOrWhiteSpace(heroText))
{
    <p class="lead">@heroText</p>
}

@if (mainContent is not null)
{
    <div class="content">@mainContent</div>
}

@if (children.Count == 0)
{
    <div class="empty">No content has been published in this section yet.</div>
}
else
{
    <section class="cards @(isEventsPage ? "cards--events" : null)" aria-label="Section items">
        @foreach (IPublishedContent child in visibleChildren)
        {
            string? cardImageUrl = null;
            string cardImageClass = "card-image";
            if (isReportsPage)
            {
                cardImageUrl = GetCardImageUrl(child, "coverImage", "featuredImage", "heroImage", "thumbnail");
            }
            else if (isNewsPage)
            {
                cardImageUrl = GetCardImageUrl(child, "featuredImage", "image", "heroImage", "thumbnail");
            }
            else if (isEventsPage)
            {
                cardImageUrl = GetCardImageUrl(child, "image", "eventImage", "listingImage", "cardImage", "featuredImage", "heroImage", "coverImage", "thumbnail");
            }
            else if (isMembershipsPage)
            {
                cardImageUrl = GetCardImageUrl(child, "logo");
                cardImageClass = "card-image card-image--logo";
            }

            cardImageUrl ??= GetCardImageUrl(child, "image", "eventImage", "listingImage", "cardImage", "featuredImage", "heroImage", "coverImage", "thumbnail", "logo");

            <a class="card" href="@child.Url()">
                @if (!string.IsNullOrWhiteSpace(cardImageUrl))
                {
                    <img class="@cardImageClass" src="@cardImageUrl" alt="@child.Name" loading="lazy" />
                }
                <h2>@child.Name</h2>
                @{ string? cardSummary = child.Value<string>("heroText") ?? child.Value<string>("summary") ?? child.Value<string>("excerpt"); }
                @if (!string.IsNullOrWhiteSpace(cardSummary))
                {
                    <p class="card-summary">@cardSummary</p>
                }
                <p>Read more</p>
            </a>
        }
    </section>

    @if (usePagination && totalPages > 1)
    {
        <nav class="pagination" aria-label="Pagination">
            @if (currentPage > 1)
            {
                <a class="pagination-link" href="@BuildPageUrl(currentPage - 1)">Previous</a>
            }

            @for (int pageNumber = firstPageToShow; pageNumber <= lastPageToShow; pageNumber++)
            {
                <a class="pagination-link @(pageNumber == currentPage ? "is-active" : null)"
                   href="@BuildPageUrl(pageNumber)"
                   aria-current="@(pageNumber == currentPage ? "page" : null)">@pageNumber</a>
            }

            @if (currentPage < totalPages)
            {
                <a class="pagination-link" href="@BuildPageUrl(currentPage + 1)">Next</a>
            }
        </nav>
    }
}
