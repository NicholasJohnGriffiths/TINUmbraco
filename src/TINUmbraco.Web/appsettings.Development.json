{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "Migration": {
    "WordPress": {
      "RunOnStartup": false,
      "JsonPath": "migration-data.news.from-api.json",
      "AvailableJsonPaths": [
        "migration-data.news.from-api.json",
        "migration-data.reports.from-api.json",
        "migration-data.pilot.from-api.json",
        "migration-data.pilot.json",
        "migration-data.sample.json"
      ],
      "ProgressInterval": 10,
      "LogItemStarts": false,
      "UpdateOnlyExisting": false,
      "FailOnMissingContentTypeAliases": true,
      "SkipTypes": [
        "nz-tech-sector-facts"
      ]
    }
  },
  "AzureKeyVault": {
    "VaultUri": "https://tinumbracokv.vault.azure.net/",
    "ConnectionStringSecretName": "umbraco-db-connection",
    "MediaConnectionStringSecretName": "umbraco-media-storage-connection"
  },
  "Umbraco": {
    "CMS": {
      "Content": {
        "MacroErrors": "Throw"
      },
      "Hosting": {
        "Debug": true
      }
    }
  }
}
