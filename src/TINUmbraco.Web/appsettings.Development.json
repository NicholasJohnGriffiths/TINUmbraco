{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "Migration": {
    "WordPress": {
      "JsonPath": "",
      "ProgressInterval": 10,
      "LogItemStarts": false
    }
  },
  "AzureKeyVault": {
    "VaultUri": "https://tinumbracokv.vault.azure.net/",
    "ConnectionStringSecretName": "umbraco-db-connection",
    "MediaConnectionStringSecretName": "umbraco-media-storage-connection"
  },
  "Umbraco": {
    "CMS": {
      "Content": {
        "MacroErrors": "Throw"
      },
      "Hosting": {
        "Debug": true
      }
    }
  }
}
