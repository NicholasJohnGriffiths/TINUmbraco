    },
    {
      "condition": "[and(parameters('enableCustomDomainBinding'), not(empty(parameters('customHostname'))))]",
      "type": "Microsoft.Web/certificates",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}-{1}-managed-cert', parameters('webAppName'), replace(parameters('customHostname'), '.', '-'))]",
      "location": "[parameters('location')]",
      "properties": {
        "canonicalName": "[parameters('customHostname')]",
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "[resourceId('Microsoft.Web/sites', parameters('webAppName'))]"
      ]
    },
    {
      "condition": "[and(parameters('enableCustomDomainBinding'), not(empty(parameters('customHostname'))))]",
      "type": "Microsoft.Web/sites/hostNameBindings",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', parameters('webAppName'), parameters('customHostname'))]",
      "properties": {
        "siteName": "[parameters('webAppName')]",
        "hostNameType": "Verified",
        "sslState": "SniEnabled",
        "thumbprint": "[reference(resourceId('Microsoft.Web/certificates', format('{0}-{1}-managed-cert', parameters('webAppName'), replace(parameters('customHostname'), '.', '-'))), '2023-12-01').thumbprint]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/certificates', format('{0}-{1}-managed-cert', parameters('webAppName'), replace(parameters('customHostname'), '.', '-')))]",
        "[resourceId('Microsoft.Web/sites', parameters('webAppName'))]"
      ]
    },
