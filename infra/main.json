    {
      "condition": "[parameters('enableStagingSlot')]",
      "type": "Microsoft.Web/sites/slots/basicPublishingCredentialsPolicies",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}/{2}', parameters('webAppName'), parameters('stagingSlotName'), 'scm')]",
      "properties": {
        "allow": false
      },
      "dependsOn": [
