      "name": "[format('{0}/{1}/{2}', parameters('mediaStorageAccountName'), 'default', parameters('imageSharpCacheContainerName'))]",
      "properties": {
        "publicAccess": "None"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', parameters('mediaStorageAccountName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults",
