      "sku": {
        "name": "[parameters('appServiceSkuName')]",
        "tier": "[if(equals(parameters('appServiceSkuName'), 'B1'), 'Basic', if(equals(parameters('appServiceSkuName'), 'S1'), 'Standard', 'PremiumV3'))]",
        "capacity": 1
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
