    {
      "condition": "[parameters('enableStagingSlot')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), resourceId('Microsoft.Web/sites/slots', parameters('webAppName'), parameters('stagingSlotName')), 'key-vault-secrets-user')]",
      "properties": {
