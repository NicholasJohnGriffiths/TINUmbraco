      "location": "[parameters('location')]",
      "kind": "app,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "DOTNETCORE|10.0",
          "alwaysOn": "[if(equals(parameters('appServiceSkuName'), 'B1'), false(), true())]",
          "minTlsVersion": "1.2",
          "scmMinTlsVersion": "1.2",
          "ftpsState": "Disabled",
          "appSettings": [
            {
              "name": "ASPNETCORE_ENVIRONMENT",
              "value": "Production"
            },
            {
              "name": "[variables('umbracoConnectionStringEnvironmentVariableName')]",
              "value": "[format('@Microsoft.KeyVault(SecretUri={0})', reference(resourceId('Microsoft.KeyVault/vaults/secrets', parameters('keyVaultName'), parameters('keyVaultSqlConnectionSecretName')), '2023-07-01').secretUriWithVersion)]"
            },
            {
              "name": "Umbraco__Storage__AzureBlob__Media__ConnectionString",
              "value": "[format('@Microsoft.KeyVault(SecretUri={0})', reference(resourceId('Microsoft.KeyVault/vaults/secrets', parameters('keyVaultName'), parameters('keyVaultMediaConnectionSecretName')), '2023-07-01').secretUriWithVersion)]"
            },
            {
              "name": "Umbraco__Storage__AzureBlob__Media__ContainerName",
              "value": "[parameters('mediaContainerName')]"
            },
            {
              "name": "Umbraco__Storage__AzureBlob__ImageSharpCache__ConnectionString",
              "value": "[format('@Microsoft.KeyVault(SecretUri={0})', reference(resourceId('Microsoft.KeyVault/vaults/secrets', parameters('keyVaultName'), parameters('keyVaultMediaConnectionSecretName')), '2023-07-01').secretUriWithVersion)]"
            },
