  "outputs": {
    "webAppName": {
      "type": "string",
      "value": "[parameters('webAppName')]"
    },
    "webAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', parameters('webAppName')), '2023-12-01').defaultHostName)]"
    },
    "stagingSlotName": {
      "type": "string",
      "value": "[if(parameters('enableStagingSlot'), parameters('stagingSlotName'), '')]"
    },
    "stagingSlotUrl": {
      "type": "string",
      "value": "[if(parameters('enableStagingSlot'), format('https://{0}-{1}.azurewebsites.net', parameters('webAppName'), parameters('stagingSlotName')), '')]"
    },
    "sqlServerName": {
      "type": "string",
      "value": "[parameters('sqlServerName')]"
    },
    "sqlDatabaseName": {
      "type": "string",
      "value": "[parameters('sqlDatabaseName')]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[parameters('keyVaultName')]"
    },
    "mediaStorageAccountName": {
      "type": "string",
      "value": "[parameters('mediaStorageAccountName')]"
    }
  }
}