      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}/{2}', parameters('mediaStorageAccountName'), 'default', parameters('mediaContainerName'))]",
