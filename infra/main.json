{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "8028215862815909620"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all Azure resources"
      }
    },
    "appName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 18,
      "metadata": {
        "description": "Global name prefix for the deployment (used for App Service and SQL resources)"
      }
    },
    "appServiceSkuName": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": [
        "B1",
        "S1",
        "P1v3"
      ],
      "metadata": {
        "description": "SKU name for the Linux App Service plan"
      }
    },
    "enableStagingSlot": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Create a staging deployment slot for safer releases"
      }
    },
    "stagingSlotName": {
      "type": "string",
      "defaultValue": "staging",
      "metadata": {
        "description": "Name of the staging slot when enabled"
      }
    },
    "enableCustomDomainBinding": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Enable custom hostname + managed certificate binding once DNS is ready"
      }
    },
    "customHostname": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Custom hostname to bind (for example: www.contoso.com)"
      }
    },
    "allowAzureServicesFirewallRule": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Allow Azure services firewall rule (0.0.0.0) on SQL Server"
      }
    },
    "sqlFirewallRules": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "Additional SQL firewall rules to allow specific client ranges"
      }
    },
    "sqlPublicNetworkAccess": {
      "type": "string",
      "defaultValue": "Enabled",
      "allowedValues": [
        "Enabled",
        "Disabled"
      ],
      "metadata": {
        "description": "Public network access mode for Azure SQL logical server"
      }
    },
    "sqlAdminLogin": {
      "type": "string",
      "metadata": {
        "description": "Azure SQL admin login name"
      }
    },
    "sqlAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Azure SQL admin login password"
      }
    },
    "sqlDatabaseName": {
      "type": "string",
      "defaultValue": "umbraco",
      "metadata": {
        "description": "Azure SQL database name for Umbraco"
      }
    },
    "appServicePlanName": {
      "type": "string",
      "defaultValue": "[format('{0}-plan', parameters('appName'))]",
      "metadata": {
        "description": "Name of the App Service plan"
      }
    },
    "webAppName": {
      "type": "string",
      "defaultValue": "[toLower(format('{0}-web', parameters('appName')))]",
      "metadata": {
        "description": "Name of the Azure Web App"
      }
    },
    "sqlServerName": {
      "type": "string",
      "defaultValue": "[toLower(format('{0}sql', parameters('appName')))]",
      "metadata": {
        "description": "Name of the Azure SQL logical server"
      }
    },
    "umbracoConnectionStringName": {
      "type": "string",
      "defaultValue": "umbracoDbDSN",
      "metadata": {
        "description": "Name of the App Service environment variable for Umbraco DB connection string"
      }
    }
  },
  "variables": {
    "sqlConnectionString": "[format('Server=tcp:{0}.{1},1433;Initial Catalog={2};Persist Security Info=False;User ID={3};Password={4};MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;', parameters('sqlServerName'), environment().suffixes.sqlServerHostname, parameters('sqlDatabaseName'), parameters('sqlAdminLogin'), parameters('sqlAdminPassword'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[parameters('appServicePlanName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "sku": {
        "name": "[parameters('appServiceSkuName')]",
        "tier": "[if(equals(parameters('appServiceSkuName'), 'B1'), 'Basic', if(equals(parameters('appServiceSkuName'), 'S1'), 'Standard', 'PremiumV3'))]",
        "capacity": 1
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('webAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "httpsOnly": true,
        "clientAffinityEnabled": false,
        "siteConfig": {
          "linuxFxVersion": "DOTNETCORE|10.0",
          "alwaysOn": "[if(equals(parameters('appServiceSkuName'), 'B1'), false(), true())]",
          "minTlsVersion": "1.2",
          "scmMinTlsVersion": "1.2",
          "ftpsState": "Disabled",
          "appSettings": [
            {
              "name": "ASPNETCORE_ENVIRONMENT",
              "value": "Production"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "1"
            }
          ],
          "connectionStrings": [
            {
              "name": "[parameters('umbracoConnectionStringName')]",
              "connectionString": "[variables('sqlConnectionString')]",
              "type": "SQLAzure"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites/basicPublishingCredentialsPolicies",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', parameters('webAppName'), 'ftp')]",
      "properties": {
        "allow": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('webAppName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites/basicPublishingCredentialsPolicies",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', parameters('webAppName'), 'scm')]",
      "properties": {
        "allow": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('webAppName'))]"
      ]
    },
    {
      "condition": "[parameters('enableStagingSlot')]",
      "type": "Microsoft.Web/sites/slots",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', parameters('webAppName'), parameters('stagingSlotName'))]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "DOTNETCORE|10.0",
          "alwaysOn": "[if(equals(parameters('appServiceSkuName'), 'B1'), false(), true())]",
          "minTlsVersion": "1.2",
          "scmMinTlsVersion": "1.2",
          "ftpsState": "Disabled",
          "appSettings": [
            {
              "name": "ASPNETCORE_ENVIRONMENT",
              "value": "Production"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "1"
            }
          ],
          "connectionStrings": [
            {
              "name": "[parameters('umbracoConnectionStringName')]",
              "connectionString": "[variables('sqlConnectionString')]",
              "type": "SQLAzure"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "[resourceId('Microsoft.Web/sites', parameters('webAppName'))]"
      ]
    },
    {
      "condition": "[parameters('enableStagingSlot')]",
      "type": "Microsoft.Web/sites/slots/basicPublishingCredentialsPolicies",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}/{2}', parameters('webAppName'), parameters('stagingSlotName'), 'ftp')]",
      "properties": {
        "allow": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites/slots', parameters('webAppName'), parameters('stagingSlotName'))]"
      ]
    },
    {
      "condition": "[parameters('enableStagingSlot')]",
      "type": "Microsoft.Web/sites/slots/basicPublishingCredentialsPolicies",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}/{2}', parameters('webAppName'), parameters('stagingSlotName'), 'scm')]",
      "properties": {
        "allow": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites/slots', parameters('webAppName'), parameters('stagingSlotName'))]"
      ]
    },
    {
      "condition": "[and(parameters('enableCustomDomainBinding'), not(empty(parameters('customHostname'))))]",
      "type": "Microsoft.Web/certificates",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}-{1}-managed-cert', parameters('webAppName'), replace(parameters('customHostname'), '.', '-'))]",
      "location": "[parameters('location')]",
      "properties": {
        "canonicalName": "[parameters('customHostname')]",
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "[resourceId('Microsoft.Web/sites', parameters('webAppName'))]"
      ]
    },
    {
      "condition": "[and(parameters('enableCustomDomainBinding'), not(empty(parameters('customHostname'))))]",
      "type": "Microsoft.Web/sites/hostNameBindings",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', parameters('webAppName'), parameters('customHostname'))]",
      "properties": {
        "siteName": "[parameters('webAppName')]",
        "hostNameType": "Verified",
        "sslState": "SniEnabled",
        "thumbprint": "[reference(resourceId('Microsoft.Web/certificates', format('{0}-{1}-managed-cert', parameters('webAppName'), replace(parameters('customHostname'), '.', '-'))), '2023-12-01').thumbprint]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/certificates', format('{0}-{1}-managed-cert', parameters('webAppName'), replace(parameters('customHostname'), '.', '-')))]",
        "[resourceId('Microsoft.Web/sites', parameters('webAppName'))]"
      ]
    },
    {
      "type": "Microsoft.Sql/servers",
      "apiVersion": "2023-08-01-preview",
      "name": "[parameters('sqlServerName')]",
      "location": "[parameters('location')]",
      "properties": {
        "administratorLogin": "[parameters('sqlAdminLogin')]",
        "administratorLoginPassword": "[parameters('sqlAdminPassword')]",
        "version": "12.0",
        "publicNetworkAccess": "[parameters('sqlPublicNetworkAccess')]",
        "minimalTlsVersion": "1.2"
      }
    },
    {
      "type": "Microsoft.Sql/servers/databases",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/{1}', parameters('sqlServerName'), parameters('sqlDatabaseName'))]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "S0",
        "tier": "Standard"
      },
      "properties": {
        "collation": "SQL_Latin1_General_CP1_CI_AS"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', parameters('sqlServerName'))]"
      ]
    },
    {
      "condition": "[and(parameters('allowAzureServicesFirewallRule'), equals(parameters('sqlPublicNetworkAccess'), 'Enabled'))]",
      "type": "Microsoft.Sql/servers/firewallRules",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/{1}', parameters('sqlServerName'), 'AllowAzureServices')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', parameters('sqlServerName'))]"
      ]
    },
    {
      "copy": {
        "name": "sqlFirewallRuleResources",
        "count": "[length(parameters('sqlFirewallRules'))]"
      },
      "condition": "[equals(parameters('sqlPublicNetworkAccess'), 'Enabled')]",
      "type": "Microsoft.Sql/servers/firewallRules",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/{1}', parameters('sqlServerName'), parameters('sqlFirewallRules')[copyIndex()].name)]",
      "properties": {
        "startIpAddress": "[parameters('sqlFirewallRules')[copyIndex()].startIpAddress]",
        "endIpAddress": "[parameters('sqlFirewallRules')[copyIndex()].endIpAddress]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', parameters('sqlServerName'))]"
      ]
    }
  ],
  "outputs": {
    "webAppName": {
      "type": "string",
      "value": "[parameters('webAppName')]"
    },
    "webAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', parameters('webAppName')), '2023-12-01').defaultHostName)]"
    },
    "stagingSlotName": {
      "type": "string",
      "value": "[if(parameters('enableStagingSlot'), parameters('stagingSlotName'), '')]"
    },
    "stagingSlotUrl": {
      "type": "string",
      "value": "[if(parameters('enableStagingSlot'), format('https://{0}-{1}.azurewebsites.net', parameters('webAppName'), parameters('stagingSlotName')), '')]"
    },
    "sqlServerName": {
      "type": "string",
      "value": "[parameters('sqlServerName')]"
    },
    "sqlDatabaseName": {
      "type": "string",
      "value": "[parameters('sqlDatabaseName')]"
    }
  }
}